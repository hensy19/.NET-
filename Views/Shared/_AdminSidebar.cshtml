@{
    var path = Context.Request.Path.ToString().ToLower();
}
<div class="admin-sidebar-v3" id="adminSidebar">
    <div class="sidebar-brand-v3">
        <div class="brand-logo-v3">
            <svg width="40" height="32" viewBox="0 0 40 32" fill="none">
                <path d="M20 0C20 0 14 10 14 16C14 22 20 32 20 32C20 32 26 22 26 16C26 10 20 0 20 0Z" fill="#10517F" fill-opacity="0.2"/>
                <path d="M20 4C20 4 15 12 15 17C15 22 20 31 20 31C20 31 25 22 25 17C25 12 20 4 20 4Z" fill="#10517F"/>
                <path d="M12 8C12 8 4 14 4 19C4 24 10 31 10 31C10 31 18 24 18 19C18 14 12 8 12 8Z" fill="#10517F" fill-opacity="0.4"/>
                <path d="M28 8C28 8 36 14 36 19C36 24 30 31 30 31C30 31 22 24 22 19C22 14 28 8 28 8Z" fill="#10517F" fill-opacity="0.4"/>
            </svg>
            <h2 class="brand-name-v3">cleoAdmin</h2>
        </div>
    </div>

    <div class="sidebar-category-title">Home</div>
    
    <nav class="sidebar-nav-v3">
        <a class="nav-item-v3 @(path == "/admin/dashboard" ? "active" : "")" asp-controller="Admin" asp-action="Dashboard">
            <span class="nav-icon-v3">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M3 3h8v8H3V3zm0 10h8v8H3v-8zM13 3h8v8h-8V3zm0 10h8v8h-8v-8z"/></svg>
            </span> 
            Dashboard
        </a>
        <a class="nav-item-v3 @(path == "/admin/users" ? "active" : "")" asp-controller="Admin" asp-action="Users">
            <span class="nav-icon-v3">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle></svg>
            </span> 
            Users
        </a>
        <a class="nav-item-v3 @(path == "/admin/content" ? "active" : "")" asp-controller="Admin" asp-action="Content">
            <span class="nav-icon-v3">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><line x1="3" y1="9" x2="21" y2="9"></line><line x1="9" y1="21" x2="9" y2="9"></line></svg>
            </span> 
            Content
        </a>
        <a class="nav-item-v3 @(path == "/admin/roles" ? "active" : "")" asp-controller="Admin" asp-action="Roles">
            <span class="nav-icon-v3">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
            </span> 
            Admin Roles
        </a>

        <!-- Collapsible Settings -->
        <div class="nav-dropdown-v3 @(path.Contains("settings") ? "expanded" : "")">
            <button class="nav-item-v3 dropdown-trigger-v3" id="settingsTrigger">
                <span class="nav-icon-v3">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"></circle><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1V11a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"></path></svg>
                </span> 
                Settings
                <span class="chevron-v3">
                    <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="6 9 12 15 18 9"></polyline></svg>
                </span>
            </button>
            <div class="dropdown-content-v3" id="settingsMenu">
                <a class="sub-nav-item-v3 @(path.Contains("settings") && (Context.Request.Query["tab"] == "general" || string.IsNullOrEmpty(Context.Request.Query["tab"])) ? "active" : "")" asp-controller="Admin" asp-action="Settings" asp-route-tab="general">
                    <span class="dot"></span> General settings
                </a>
                <a class="sub-nav-item-v3 @(Context.Request.Query["tab"] == "privacy" ? "active" : "")" asp-controller="Admin" asp-action="Settings" asp-route-tab="privacy">
                    <span class="dot"></span> Privacy and security
                </a>
                <a class="sub-nav-item-v3 @(Context.Request.Query["tab"] == "content" ? "active" : "")" asp-controller="Admin" asp-action="Settings" asp-route-tab="content">
                    <span class="dot"></span> content control
                </a>
                <a class="sub-nav-item-v3 @(Context.Request.Query["tab"] == "data" ? "active" : "")" asp-controller="Admin" asp-action="Settings" asp-route-tab="data">
                    <span class="dot"></span> Data Management
                </a>
            </div>
        </div>
    </nav>

    <div class="sidebar-section-divider"></div>

    <div class="sidebar-category-title">General</div>
    <nav class="sidebar-nav-v3">
        <a class="nav-item-v3" href="#">
            <span class="nav-icon-v3">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><path d="M12 8v8M8 12h8"></path></svg>
            </span>
            Setup System
        </a>
        <a class="nav-item-v3" href="#">
            <span class="nav-icon-v3">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path></svg>
            </span>
            Support Team
        </a>
    </nav>

    <div class="sidebar-footer-v3">
        <div class="sidebar-users-section">
            <div style="font-size: 0.75rem; font-weight: 600; color: #94A3B8; margin-bottom: 0.75rem; padding: 0 0.25rem;">Most active users</div>
            <div class="sidebar-user-list">
                <div class="sidebar-user-item">
                    <span class="status-dot-v3 red"></span> Hensy Patel
                </div>
                <div class="sidebar-user-item">
                    <span class="status-dot-v3 blue"></span> Ridhdhi Raval
                </div>
                <div class="sidebar-user-item">
                    <span class="status-dot-v3 purple"></span> Komal Mishra
                </div>
            </div>
        </div>

        <div class="sidebar-section-divider" style="margin: 1.5rem 0;"></div>

        <form asp-controller="Public" asp-action="Logout" method="post">
            @Html.AntiForgeryToken()
            <button type="submit" class="logout-btn-v3">
                <span class="logout-icon-v3">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path><polyline points="16 17 21 12 16 7"></polyline><line x1="21" y1="12" x2="9" y2="12"></line></svg>
                </span>
                Logout
            </button>
        </form>
    </div>
</div>

<script>
    document.getElementById('settingsTrigger').addEventListener('click', function() {
        const parent = this.parentElement;
        parent.classList.toggle('expanded');
    });
</script>
