@{
	Layout = null;
}

<!DOCTYPE html>
<html>
<head>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<title>@ViewData["Title"] - Flora</title>

	<link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
	<link rel="stylesheet" href="~/css/user/layout.css" />
	<link rel="stylesheet" href="~/css/user/dashboard.css" />
	<link rel="stylesheet" href="~/css/user/calendar.css" />
	<link rel="stylesheet" href="~/css/user/logperiod.css" />
	<link rel="stylesheet" href="~/css/user/history.css" />
	<link rel="stylesheet" href="~/css/user/logsymptoms.css" />
	<link rel="stylesheet" href="~/css/user/tips.css" />


</head>
<body>

	<!-- Navbar -->
	<nav class="navbar navbar-expand-lg user-navbar">
		<div class="container-fluid">
			<a class="navbar-brand text-white fw-bold"
			   asp-controller="User"
			   asp-action="Dashboard">
				FLORA
			</a>

			<div class="collapse navbar-collapse">
				<ul class="navbar-nav ms-auto">

					<li class="nav-item">
						<a class="nav-link text-white"
						   asp-controller="User"
						   asp-action="Dashboard">
							Dashboard
						</a>
					</li>

					<li class="nav-item">
						<a class="nav-link text-white"
						   href="#">
							Log Symptoms
						</a>
					</li>

					<a class="nav-link text-white"
					   asp-controller="User"
					   asp-action="Calendar">
						Calendar
					</a>
					<a class="nav-link text-white"
					   asp-controller="User"
					   asp-action="Tips">
						Tips
					</a>

					<li class="nav-item">
						<a class="nav-link text-danger"
						   asp-controller="Account"
						   asp-action="Logout">
							Logout
						</a>
					</li>

				</ul>
			</div>
		</div>
	</nav>

	<!-- Page Content -->
	<div class="container mt-4">
		@RenderBody()
	</div>

	<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>