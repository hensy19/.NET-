@{
    ViewData["Title"] = "Not Found";
}
@section Styles {
    <link rel="stylesheet" href="~/css/NotFound.css" />
}
<div class="onboarding-page">
    <div class="log-card onboarding-card">
        <div class="card-logo">
             <img src="~/images/logo.png" alt="CLEO Logo" />
        </div>
        
        <div class="onboarding-content">
            <h1 class="card-title">404</h1>
            <h2 class="card-subtitle">Page Not Found</h2>
            <p class="card-subtitle">The page you are looking for doesn't exist or has been moved.</p>

            <div class="onboarding-actions">
                <a href="/" class="btn btn-primary account-btn">Go to Home</a>
            </div>
        </div>
    </div>
</div>
