@{
    ViewData["Title"] = "Email Sent";
}
@section Styles {
    <link rel="stylesheet" href="~/css/ForgotPassword.css" />
}

<div class="log-page forgot-password-page">
    <div class="log-card forgot-card">
        <div class="card-logo">
             <img src="~/images/logo.png" alt="CLEO Logo" />
        </div>
        
        <div class="forgot-content">
            <h1 class="card-title">Check Your Email</h1>
            <p class="card-subtitle">We've sent a password reset link to your email address. It should arrive in a few minutes.</p>

            <div class="onboarding-actions">
                <a asp-action="Login" asp-controller="Public" class="btn btn-primary account-btn">Return to Login</a>
            </div>
        </div>

        <div class="card-footer">
            <p class="demo-text">Didn't receive the email? <a href="#">Resend Link</a></p>
        </div>
    </div>
</div>
