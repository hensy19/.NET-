@{
    ViewData["Title"] = "Change Password";
}
@section Styles {
    <link rel="stylesheet" href="~/css/ChangePassword.css" />
}

<div class="change-password-page-v3">
    <!-- Main Card -->
    <div class="password-card-v3">
        <!-- Left: Form -->
        <div class="password-form-section-v3">
            <h1 class="page-title-v3">Change your password</h1>
            
            <form method="post" action="/Dashboard/ChangePassword" class="password-form-v3">
                @Html.AntiForgeryToken()
                
                <div class="form-group-v3">
                    <label>Current Password</label>
                    <input type="password" name="currentPassword" placeholder="Enter your current password" required />
                </div>

                <div class="form-group-v3">
                    <label>New Password</label>
                    <input type="password" name="newPassword" placeholder="Enter a new password" required />
                </div>

                <div class="form-group-v3">
                    <label>Confirm Password</label>
                    <input type="password" name="confirmPassword" placeholder="Re-enter your password" required />
                </div>

                <div class="form-actions-v3">
                    <button type="submit" class="btn-save-password-v3">Save password</button>
                </div>
            </form>

            @if (TempData["PassMessage"] != null)
            {
                <p class="status-msg-v3 success">@TempData["PassMessage"]</p>
            }
        </div>

        <!-- Right: Illustration -->
        <div class="password-visual-section-v3">
            <div class="monitor-wrapper-v3">
                <div class="monitor-screen">
                    <div class="mock-login">
                        <div class="mock-avatar"></div>
                        <div class="mock-bar"></div>
                        <div class="mock-bar short"></div>
                    </div>
                </div>
                <div class="monitor-stand"></div>
                <div class="monitor-base"></div>
            </div>
        </div>
    </div>
</div>
