<div class="auth-wrapper">
    <div class="auth-container">

        <div class="auth-image">
            <img src="~/images/signin.svg" alt="">
        </div>

        <div class="auth-form">
            <h2>Hello Again!</h2>
            <p>Welcome back you've been missed!</p>
            @if (ViewBag.Error != null)
            {
                <div class="error-text">@ViewBag.Error</div>
            }
            <form asp-controller="Auth" asp-action="Login" method="post" onsubmit="return validateLogin()">

                <div class="form-group">
                    <input type="email" id="loginEmail" name="Email" placeholder=" " required>
                    <label>Email Address</label>
                    <div class="error-text" id="loginEmailError"></div>
                </div>

                <div class="form-group password-wrapper">
                    <input type="password" id="loginPassword" name="Password" placeholder=" " required>
                    <label>Password</label>
                    <span class="toggle-password" onclick="togglePassword('loginPassword')">Show</span>
                    <div class="error-text" id="loginPasswordError"></div>
                </div>

                <button type="submit" class="auth-btn">
                    Sign In
                </button>

            </form>

            <div class="auth-footer">
                Don’t have an account?
                <a asp-controller="Home" asp-action="Register">Sign up</a>
            </div>

        </div>

    </div>
</div>