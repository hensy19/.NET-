@{
    ViewData["Title"] = "Admin Login";
    Layout = null; // Use a standalone layout for the login page
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CLEO</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/global.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/variables.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/AdminLogin.css" asp-append-version="true" />
</head>
<body>
    <div class="admin-login-page">
        <div class="login-split-card">
            <!-- Left Side: Illustration -->
            <div class="login-left-v3">
                <img src="~/images/admin_login_illustration.png" alt="Illustration" class="login-illustration-v3" />
            </div>

            <!-- Right Side: Form -->
            <div class="login-right-v3">
                <div class="login-brand-v3">
                    <span class="brand-icon-v3">
                        <svg width="60" height="48" viewBox="0 0 40 32" fill="none">
                            <path d="M20 0C20 0 14 10 14 16C14 22 20 32 20 32C20 32 26 22 26 16C26 10 20 0 20 0Z" fill="currentColor" fill-opacity="0.2"/>
                            <path d="M20 4C20 4 15 12 15 17C15 22 20 31 20 31C20 31 25 22 25 17C25 12 20 4 20 4Z" fill="currentColor"/>
                            <path d="M12 8C12 8 4 14 4 19C4 24 10 31 10 31C10 31 18 24 18 19C18 14 12 8 12 8Z" fill="currentColor" fill-opacity="0.4"/>
                            <path d="M28 8C28 8 36 14 36 19C36 24 30 31 30 31C30 31 22 24 22 19C22 14 28 8 28 8Z" fill="currentColor" fill-opacity="0.4"/>
                        </svg>
                    </span>
                    <h1 class="brand-title-v3">Admin Login</h1>
                </div>

                <form method="post" action="/Admin/Login" class="login-form-v3">
                    @Html.AntiForgeryToken()
                    <div class="form-group-v3">
                        <label class="form-label-v3">Email Address</label>
                        <input type="email" name="email" class="input-field-v3" placeholder="abc@example.com" required />
                    </div>

                    <div class="form-group-v3">
                        <label class="form-label-v3">Password</label>
                        <input type="password" name="password" class="input-field-v3" placeholder="Enter your password" required />
                    </div>

                    <a href="#" class="forgot-link-v3">Forgot password?</a>

                    <button type="submit" class="login-btn-v3">
                        <span>Sign in</span>
                        <span class="btn-icon-v3">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"></path><polyline points="10 17 15 12 10 7"></polyline><line x1="15" y1="12" x2="3" y2="12"></line></svg>
                        </span>
                    </button>
                </form>
            </div>
        </div>
    </div>
</body>
</html>
