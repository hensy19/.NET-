@{
    ViewData["Title"] = "User Management";
    Layout = "_AdminLayout";
}
@section Styles {
    <link rel="stylesheet" href="~/css/AdminUsers.css" asp-append-version="true" />
    <style>
        .content-stats-grid-v3 {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 1.5rem;
            margin-bottom: 2rem;
        }

        .content-stat-card-v3 {
            background-color: #DBEAFE;
            padding: 1.5rem;
            border-radius: 12px;
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
        }

        .content-stat-card-v3 .stat-icon-v3 {
            width: 32px;
            height: 32px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.25rem;
            color: #1E293B;
        }

        .content-stat-card-v3 .stat-value-v3 {
            font-size: 1.5rem;
            font-weight: 700;
            color: #0F172A;
            margin-top: 0.5rem;
        }

        .content-stat-card-v3 .stat-label-v3 {
            font-size: 0.85rem;
            font-weight: 600;
            color: #475569;
        }

        /* Toolbar */
        .content-toolbar-v3 {
            display: flex;
            gap: 1rem;
            margin-bottom: 2rem;
            align-items: center;
        }

        .content-search-v3 {
            flex: 1;
            position: relative;
        }

        .content-search-v3 input {
            width: 100%;
            padding: 0.75rem 1rem 0.75rem 2.5rem;
            border-radius: 2rem;
            border: 1px solid #E2E8F0;
            background-color: #F1F5F9;
            font-size: 0.9rem;
        }

        .content-search-v3 i {
            position: absolute;
            left: 1rem;
            top: 50%;
            transform: translateY(-50%);
            color: #64748B;
        }

        .btn-filter-v3 {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            padding: 0.75rem 1.5rem;
            background-color: #F1F5F9;
            border: 1px solid #E2E8F0;
            border-radius: 2rem;
            font-size: 0.9rem;
            font-weight: 600;
            color: #475569;
            cursor: pointer;
        }

        /* Table Card */
        .tips-management-v3 {
            background-color: white;
            border-radius: 16px;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
            overflow: hidden;
        }

        .tips-table-header-v3 {
            padding: 1.5rem;
            border-bottom: 1px solid #F1F5F9;
        }

        .tips-table-header-v3 h3 {
            margin: 0;
            font-size: 1.1rem;
            font-weight: 700;
            color: #0F172A;
        }

        .tips-table-header-v3 p {
            margin: 0.25rem 0 0;
            font-size: 0.8rem;
            color: #64748B;
        }

        .status-pill-v3 {
            padding: 0.25rem 0.75rem;
            border-radius: 1rem;
            font-size: 0.75rem;
            font-weight: 700;
            text-transform: capitalize;
        }

        .status-pill-v3.active { background-color: #DCFCE7; color: #166534; }
        .status-pill-v3.inactive { background-color: #F1F5F9; color: #64748B; }

        .action-icon-v3 {
            padding: 0.4rem;
            background: none;
            border: none;
            cursor: pointer;
            color: #10517F;
            border-radius: 4px;
            transition: background-color 0.2s;
        }

        .action-icon-v3:hover { background-color: #F1F5F9; }
        .action-icon-v3.delete { color: #EF4444; }
    </style>
}

<div class="admin-users-v3">
    <div class="page-header-v3">
        <div class="header-info-v3">
            <h1 class="page-title-v3">User Management</h1>
            <p class="subtitle-v3">Manage and track user activity</p>
        </div>
        <div class="header-actions-v3">
            <button class="btn-primary-v3" style="padding: 0.7rem 1.5rem; border-radius: 2rem;">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
                New User
            </button>
        </div>
    </div>

    <!-- User Stats -->
    <div class="content-stats-grid-v3">
        <div class="content-stat-card-v3">
            <div class="stat-icon-v3">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
            </div>
            <h3 class="stat-value-v3">2,481</h3>
            <span class="stat-label-v3">Total Users</span>
        </div>
        <div class="content-stat-card-v3">
            <div class="stat-icon-v3">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
            </div>
            <h3 class="stat-value-v3">1,783</h3>
            <span class="stat-label-v3">Active Users</span>
        </div>
        <div class="content-stat-card-v3">
            <div class="stat-icon-v3">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="8.5" cy="7" r="4"></circle><line x1="20" y1="8" x2="20" y2="14"></line><line x1="23" y1="11" x2="17" y2="11"></line></svg>
            </div>
            <h3 class="stat-value-v3">124</h3>
            <span class="stat-label-v3">New Users</span>
        </div>
        <div class="content-stat-card-v3">
            <div class="stat-icon-v3">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
            </div>
            <h3 class="stat-value-v3">2,105</h3>
            <span class="stat-label-v3">Verified</span>
        </div>
    </div>

    <!-- Toolbar -->
    <div class="content-toolbar-v3">
        <div class="content-search-v3">
            <i><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg></i>
            <input type="text" placeholder="Search by name or email...">
        </div>
        <button class="btn-filter-v3">
            Roles 
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"></polyline></svg>
        </button>
    </div>

    <!-- Users Table -->
    <div class="tips-management-v3">
        <div class="tips-table-header-v3">
            <h3>Manage Users</h3>
            <p>User accounts and activity</p>
        </div>
        <table class="users-table-v3">
            <thead>
                <tr>
                    <th style="width: 25%;">Name</th>
                    <th style="width: 15%;">User ID</th>
                    <th style="width: 25%;">Email</th>
                    <th style="width: 15%;">Status</th>
                    <th style="width: 20%;">Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in ViewBag.UsersList)
                {
                    <tr>
                        <td>
                            <div class="user-cell-v3">
                                <img src="https://ui-avatars.com/api/?name=@user.Name&background=random" alt="Avatar" class="user-avatar-v3" style="width: 32px; height: 32px; border-radius: 50%; margin-right: 10px;" />
                                <span style="font-weight: 700; color: #0F172A;">@user.Name</span>
                            </div>
                        </td>
                        <td><span style="font-weight: 600; color: #64748B;">#CLO-@user.Id</span></td>
                        <td style="color: #475569;">@user.Email</td>
                        <td>
                            <span class="status-pill-v3 @(user.Status.ToString().ToLower())">
                                @user.Status
                            </span>
                        </td>
                        <td>
                            <div class="action-btns-v3">
                                <button class="action-icon-v3" title="View">
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>
                                </button>
                                <button class="action-icon-v3" title="Edit">
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 1 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg>
                                </button>
                                <button class="action-icon-v3 delete" title="Delete">
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg>
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
