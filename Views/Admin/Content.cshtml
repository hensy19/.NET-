@{
    ViewData["Title"] = "Content Management";
    Layout = "_AdminLayout";
}
@section Styles {
    <link rel="stylesheet" href="~/css/AdminUsers.css" asp-append-version="true" />
    <style>
        .content-stats-grid-v3 {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 1.5rem;
            margin-bottom: 2rem;
        }

        .content-stat-card-v3 {
            background-color: #DBEAFE;
            padding: 1.5rem;
            border-radius: 12px;
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
        }

        .content-stat-card-v3 .stat-icon-v3 {
            width: 32px;
            height: 32px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.25rem;
            color: #1E293B;
        }

        .content-stat-card-v3 .stat-value-v3 {
            font-size: 1.5rem;
            font-weight: 700;
            color: #0F172A;
            margin-top: 0.5rem;
        }

        .content-stat-card-v3 .stat-label-v3 {
            font-size: 0.85rem;
            font-weight: 600;
            color: #475569;
        }

        /* Toolbar */
        .content-toolbar-v3 {
            display: flex;
            gap: 1rem;
            margin-bottom: 2rem;
            align-items: center;
        }

        .content-search-v3 {
            flex: 1;
            position: relative;
        }

        .content-search-v3 input {
            width: 100%;
            padding: 0.75rem 1rem 0.75rem 2.5rem;
            border-radius: 2rem;
            border: 1px solid #E2E8F0;
            background-color: #F1F5F9;
            font-size: 0.9rem;
        }

        .content-search-v3 i {
            position: absolute;
            left: 1rem;
            top: 50%;
            transform: translateY(-50%);
            color: #64748B;
        }

        .btn-filter-v3 {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            padding: 0.75rem 1.5rem;
            background-color: #F1F5F9;
            border: 1px solid #E2E8F0;
            border-radius: 2rem;
            font-size: 0.9rem;
            font-weight: 600;
            color: #475569;
            cursor: pointer;
        }

        /* Table Card */
        .tips-management-v3 {
            background-color: white;
            border-radius: 16px;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
            overflow: hidden;
        }

        .tips-table-header-v3 {
            padding: 1.5rem;
            border-bottom: 1px solid #F1F5F9;
        }

        .tips-table-header-v3 h3 {
            margin: 0;
            font-size: 1.1rem;
            font-weight: 700;
            color: #0F172A;
        }

        .tips-table-header-v3 p {
            margin: 0.25rem 0 0;
            font-size: 0.8rem;
            color: #64748B;
        }

        .status-pill-v3 {
            padding: 0.25rem 0.75rem;
            border-radius: 1rem;
            font-size: 0.75rem;
            font-weight: 700;
            text-transform: capitalize;
        }

        .status-pill-v3.published { background-color: #DCFCE7; color: #166534; }
        .status-pill-v3.draft { background-color: #FEF9C3; color: #854D0E; }

        .action-icon-v3 {
            padding: 0.4rem;
            background: none;
            border: none;
            cursor: pointer;
            color: #10517F;
            border-radius: 4px;
            transition: background-color 0.2s;
        }

        .action-icon-v3:hover { background-color: #F1F5F9; }
        .action-icon-v3.delete { color: #EF4444; }
    </style>
}

<div class="admin-users-v3">
    <div class="page-header-v3">
        <div class="header-info-v3">
            <h1 class="page-title-v3">Content management</h1>
            <p class="subtitle-v3">Manage articles and guides</p>
        </div>
        <div class="header-actions-v3">
            <button class="btn-primary-v3" style="padding: 0.7rem 1.5rem; border-radius: 2rem;">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
                New Article
            </button>
        </div>
    </div>

    <!-- Content Stats -->
    <div class="content-stats-grid-v3">
        <div class="content-stat-card-v3">
            <div class="stat-icon-v3">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"></path></svg>
            </div>
            <h3 class="stat-value-v3">13</h3>
            <span class="stat-label-v3">Total Tips</span>
        </div>
        <div class="content-stat-card-v3">
            <div class="stat-icon-v3">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="12" y1="18" x2="8" y2="18"></line><line x1="16" y1="14" x2="8" y2="14"></line></svg>
            </div>
            <h3 class="stat-value-v3">12</h3>
            <span class="stat-label-v3">Published</span>
        </div>
        <div class="content-stat-card-v3">
            <div class="stat-icon-v3">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 1 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg>
            </div>
            <h3 class="stat-value-v3">2</h3>
            <span class="stat-label-v3">Drafts</span>
        </div>
        <div class="content-stat-card-v3">
            <div class="stat-icon-v3">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"></rect><rect x="14" y="3" width="7" height="7"></rect><rect x="14" y="14" width="7" height="7"></rect><rect x="3" y="14" width="7" height="7"></rect></svg>
            </div>
            <h3 class="stat-value-v3">6</h3>
            <span class="stat-label-v3">Categories</span>
        </div>
    </div>

    <!-- Toolbar -->
    <div class="content-toolbar-v3">
        <div class="content-search-v3">
            <i><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg></i>
            <input type="text" placeholder="Search articles...">
        </div>
        <button class="btn-filter-v3">
            Categories 
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"></polyline></svg>
        </button>
    </div>

    <!-- Tips Table -->
    <div class="tips-management-v3">
        <div class="tips-table-header-v3">
            <h3>Manage Tips</h3>
            <p>Tips, advice and articles</p>
        </div>
        <table class="users-table-v3">
            <thead>
                <tr>
                    <th style="width: 15%;">Category</th>
                    <th style="width: 25%;">Title</th>
                    <th style="width: 35%;">Content</th>
                    <th style="width: 10%;">Status</th>
                    <th style="width: 15%;">Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in ViewBag.ArticlesList)
                {
                    <tr>
                        <td><span style="font-weight: 600; color: #64748B;">@item.Category</span></td>
                        <td style="font-weight: 700; color: #0F172A;">@item.Title</td>
                        <td style="font-size: 0.85rem; color: #475569;">@(item.Content.Length > 50 ? item.Content.Substring(0, 50) + "..." : item.Content)</td>
                        <td>
                            <span class="status-pill-v3 @(item.Status.ToString().ToLower())">
                                @item.Status
                            </span>
                        </td>
                        <td>
                            <div class="action-btns-v3">
                                <button class="action-icon-v3" title="View">
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>
                                </button>
                                <button class="action-icon-v3" title="Edit">
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 1 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg>
                                </button>
                                <button class="action-icon-v3 delete" title="Delete">
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg>
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Add New Article Modal -->
<div class="modal-overlay-v3" id="addArticleModal">
    <div class="modal-content-v3">
        <form asp-controller="Admin" asp-action="AddArticle" method="post">
            @Html.AntiForgeryToken()
            <div class="modal-header-v3" style="padding: 1.5rem 1.75rem; display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid #F1F5F9;">
                <h2 style="font-size: 1.15rem; font-weight: 700; color: #1E293B; margin: 0;">Add new article</h2>
                <button type="button" class="modal-close-v3" onclick="closeAddArticleModal()" style="border: none; background: none; color: #64748B; cursor: pointer; padding: 0.25rem; display: flex; align-items: center; justify-content: center; border-radius: 6px;">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
                </button>
            </div>
            <div class="modal-body-v3" style="padding: 1.75rem;">
                <div class="form-group-v3" style="margin-bottom: 1.25rem;">
                    <label style="display: block; font-size: 0.85rem; font-weight: 600; color: #475569; margin-bottom: 0.5rem;">Article Title</label>
                    <input type="text" name="title" placeholder="Enter article title" required style="width: 100%; padding: 0.75rem; border-radius: 8px; border: 1px solid #E2E8F0; font-size: 0.85rem;" />
                </div>
                <div class="form-group-v3" style="margin-bottom: 1.25rem;">
                    <label style="display: block; font-size: 0.85rem; font-weight: 600; color: #475569; margin-bottom: 0.5rem;">Category</label>
                    <select name="category" style="width: 100%; padding: 0.75rem; border-radius: 8px; border: 1px solid #E2E8F0; font-size: 0.85rem; background-color: white;">
                        <option value="Menstrual health">Menstrual health</option>
                        <option value="Exercise">Exercise</option>
                        <option value="Nutrition">Nutrition</option>
                        <option value="Hygiene">Hygiene</option>
                    </select>
                </div>
                <div class="form-group-v3" style="margin-bottom: 1.25rem;">
                    <label style="display: block; font-size: 0.85rem; font-weight: 600; color: #475569; margin-bottom: 0.5rem;">Full Content</label>
                    <textarea name="content" rows="4" placeholder="Write your article content here..." required style="width: 100%; padding: 0.75rem; border-radius: 8px; border: 1px solid #E2E8F0; font-size: 0.85rem; font-family: inherit; resize: vertical;"></textarea>
                </div>
            </div>
            <div class="modal-footer-v3" style="padding: 0.5rem 1.75rem 2rem; display: flex; justify-content: center;">
                <button type="submit" class="btn-add-modal-v3" style="display: flex; align-items: center; gap: 0.5rem; padding: 0.75rem 2rem; background-color: #10517F; color: white; border: none; border-radius: 50px; font-size: 0.85rem; font-weight: 600; cursor: pointer;">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
                    Post Article
                </button>
            </div>
        </form>
    </div>
</div>

<!-- Modal Shared Styles Injection -->
<style>
    .modal-overlay-v3 {
        position: fixed; top: 0; left: 0; right: 0; bottom: 0;
        background-color: rgba(0, 0, 0, 0.4);
        display: flex; align-items: center; justify-content: center;
        z-index: 1000; opacity: 0; pointer-events: none;
        transition: opacity 0.3s ease;
    }
    .modal-overlay-v3.active { opacity: 1; pointer-events: all; }
    .modal-content-v3 {
        background-color: white; width: 100%; max-width: 500px;
        border-radius: 20px; box-shadow: 0 10px 40px rgba(0, 0, 0, 0.15);
        overflow: hidden; transform: translateY(20px);
        transition: transform 0.3s ease;
    }
    .modal-overlay-v3.active .modal-content-v3 { transform: translateY(0); }
    .modal-close-v3:hover { background-color: #F1F5F9; color: #1E293B; }
    .btn-add-modal-v3:hover { background-color: #0d436a; }
</style>

<script>
    function openAddArticleModal() {
        document.getElementById('addArticleModal').classList.add('active');
    }
    function closeAddArticleModal() {
        document.getElementById('addArticleModal').classList.remove('active');
    }
    // Allow closing by clicking outside
    window.addEventListener('click', function(event) {
        const modal = document.getElementById('addArticleModal');
        if (event.target == modal) closeAddArticleModal();
    });

    // Update main button
    document.querySelector('.btn-primary-v3').setAttribute('onclick', 'openAddArticleModal()');
</script>
