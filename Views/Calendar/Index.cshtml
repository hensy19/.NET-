@{
    ViewData["Title"] = "Cycle Calendar";
}
@section Styles {
    <link rel="stylesheet" href="~/css/Calendar.css" />
}

<div class="calendar-page-v3">
    <!-- Breadcrumb / Header Area -->
    <div class="calendar-header-v3">
        <div class="header-left">
            <a asp-controller="Dashboard" asp-action="Index" class="back-link">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M19 12H5M5 12L12 19M5 12L12 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
            </a>
            <div class="title-group">
                <h1>Cycle Calendar</h1>
                <p>Track your cycle across the month</p>
            </div>
        </div>
        <div class="header-right">
            <a asp-controller="Dashboard" asp-action="LogPeriod" class="btn-cal-v3 btn-light-blue">Log Period</a>
            <a asp-controller="Dashboard" asp-action="History" class="btn-cal-v3 btn-accent-blue">View History</a>
        </div>
    </div>

    <!-- Main Calendar Card -->
    <div class="calendar-container-v3">
        <div class="month-selector-v3">
            <h2>February 2026</h2>
            <div class="selector-actions">
                <button class="nav-arrow-btn">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
                </button>
                <button class="nav-arrow-btn">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
                </button>
            </div>
        </div>

        <div class="calendar-grid-v3">
            <!-- Day Headers -->
            <div class="day-header">Sun</div>
            <div class="day-header">Mon</div>
            <div class="day-header">Tue</div>
            <div class="day-header">Wed</div>
            <div class="day-header">Thu</div>
            <div class="day-header">Fri</div>
            <div class="day-header">Sat</div>

            @for (int i = 1; i <= 28; i++)
            {
                var highlight = ((dynamic[])ViewBag.CalendarDays).FirstOrDefault(d => d.Day == i);
                string highlightClass = highlight != null ? $"is-{highlight.Type}" : "";
                bool isToday = (i == 19); // Hardcoded for matching the image (February 19th)

                <div class="calendar-cell-v3 @highlightClass @(isToday ? "is-today" : "")">
                    <span class="cell-number">@i</span>
                </div>
            }
        </div>
    </div>

    <!-- Legend Section -->
    <div class="legend-card-v3">
        <h3 class="legend-title">Legend</h3>
        <div class="legend-items-v3">
            <div class="legend-unit">
                <span class="swatch is-period"></span>
                <span class="label">Period Days</span>
            </div>
            <div class="legend-unit">
                <span class="swatch is-ovulation"></span>
                <span class="label">Ovulation</span>
            </div>
            <div class="legend-unit">
                <span class="swatch is-fertile"></span>
                <span class="label">Fertile Window</span>
            </div>
            <div class="legend-unit">
                <span class="swatch is-today-border"></span>
                <span class="label">Today</span>
            </div>
        </div>
    </div>
</div>
