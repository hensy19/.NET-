@{
    ViewData["Title"] = "Onboarding";
}
@section Styles {
    <link rel="stylesheet" href="~/css/Onboarding.css" />
}
<div class="onboarding-page">
    <div class="log-card onboarding-card">
        <div class="card-logo">
             <img src="~/images/logo.png" alt="CLEO Logo" />
        </div>
        
        <div class="progress-container">
            <div class="progress-bar">
                <div class="progress-fill" style="width: 25%"></div>
            </div>
            <p class="progress-text">Step 1 of 4</p>
        </div>

        <div class="onboarding-content">
            <h1 class="card-title">Let's get to know you</h1>
            <p class="card-subtitle">This helps us personalize your tracking experience</p>

            <form method="post" action="/onboarding" class="log-form">
                @Html.AntiForgeryToken()
                <div class="form-group">
                    <label class="input-label">How old are you?</label>
                    <input type="number" name="age" class="input-field" placeholder="Enter your age" required />
                </div>

                <div class="onboarding-actions">
                    <button type="button" class="btn btn-outline account-btn disabled" disabled>Back</button>
                    <button type="submit" class="btn btn-primary account-btn">Next Step</button>
                </div>
            </form>
        </div>

        <div class="card-footer">
             <p class="skip-text">You can update this information later in settings</p>
        </div>
    </div>
</div>
